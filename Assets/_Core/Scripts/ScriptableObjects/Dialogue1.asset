  dialogueSection:
  - dialogue: "Hey- You there, with the big teeths. Mind giving a <color=\"red\">paw
      to a friend?\r"
    sprite: {fileID: 21300000, guid: 665239132cf663b42aa5f113cbcdca32, type: 3}
    isPlayer: 0
  - dialogue: ...
    sprite: {fileID: -153225838, guid: 002f39413b814044cab906a1394a4b8a, type: 3}
    isPlayer: 1
  - dialogue: "<i>Yes yes</i>, I speak, we\u2019re not going to make a chicken out
      of a feather, are we?"
    sprite: {fileID: 21300000, guid: 29ed507b1e2dbad48913d6e7fc3fe042, type: 3}
    isPlayer: 0
  - dialogue: "If you had the kindness to free me, I could help you with <b>the mountain
      of trouble </b>you\u2019ve got yourself in."
    sprite: {fileID: 21300000, guid: 29ed507b1e2dbad48913d6e7fc3fe042, type: 3}
    isPlayer: 0
  - dialogue: "About time. This lock didn\u2019t look as protected as it seemed,
      this old man isn\u2019t as smart as I thought."
    sprite: {fileID: 21300000, guid: 29ed507b1e2dbad48913d6e7fc3fe042, type: 3}
    isPlayer: 0
  - dialogue: Hey yo stfu <allcaps><color="red">goofy ass bird
    sprite: {fileID: -590973308, guid: 002f39413b814044cab906a1394a4b8a, type: 3}
    isPlayer: 1
